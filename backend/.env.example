# Production Environment Variables Example
# Copy this file to .env and replace the values with your actual production secrets

# ----------------------------------------
# Node Environment
# ----------------------------------------
# Critical: Set to 'production' to enable optimized caching and hide error stack traces
NODE_ENV=production

# ----------------------------------------
# Server Configuration
# ----------------------------------------
PORT=5001

# ----------------------------------------
# Frontend Connection & CORS
# ----------------------------------------
# The exact URL of your deployed frontend (e.g., https://app.analytics.com)
# No trailing slash. This strictly whitelists CORS for this domain only.
FRONTEND_URL=https://your-production-domain.com

# ----------------------------------------
# Database Connection
# ----------------------------------------
# Use a strong, authenticated MongoDB connection string
# Examples: 
# MongoDB Atlas: mongodb+srv://<user>:<password>@cluster0.mongodb.net/health_analytics?retryWrites=true&w=majority
# Dedicated Server: mongodb://user:pass@10.0.0.5:27017/health_analytics?authSource=admin
MONGODB_URI=mongodb://localhost:27017/health_analytics

# ----------------------------------------
# Security
# ----------------------------------------
# Must be a long, cryptographically secure random string (e.g., generated via `openssl rand -hex 64`)
# Used to sign stateless JWT tokens
JWT_SECRET=generate_a_very_long_secure_random_string_here_and_do_not_share_it

# How long user sessions last before requiring re-login (e.g., 1d, 7d, 24h)
JWT_EXPIRES_IN=24h
